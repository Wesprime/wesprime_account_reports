<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_partner_ledger_pdf" model="ir.actions.report">
        <field name="name">Partner Ledger</field>
        <field name="model">wesprime.partner.ledger.wizard</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">wesprime_account_reports.report_partner_ledger_pdf</field>
        <field name="report_file">wesprime_account_reports.report_partner_ledger_pdf</field>
        <field name="print_report_name">'Partner Ledger - %s' % (object.company_id.name)</field>
    </record>

    <template id="report_partner_ledger_pdf">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page">
                        <h2>Partner Ledger</h2>
                        <div class="row mb-3">
                            <div class="col-6">
                                <strong>Company:</strong>
                                <span t-field="doc.company_id"/>
                            </div>
                            <div class="col-6 text-end">
                                <strong>Period:</strong>
                                <span t-esc="doc.date_from or ''"/>
                                <span> - </span>
                                <span t-esc="doc.date_to or ''"/>
                            </div>
                        </div>
                        <table class="table table-sm o_main_table">
                            <thead>
                                <tr>
                                    <th>Date</th>
                                    <th>Partner</th>
                                    <th>Journal</th>
                                    <th>Entry</th>
                                    <th>Account</th>
                                    <th>Label</th>
                                    <th class="text-end">Debit</th>
                                    <th class="text-end">Credit</th>
                                    <th class="text-end">Balance</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr t-foreach="doc.result_line_ids" t-as="line" t-att-class="'fw-bold table-light' if line.is_initial else ''">
                                    <td><span t-field="line.date"/></td>
                                    <td><span t-field="line.partner_id"/></td>
                                    <td><span t-field="line.journal_id"/></td>
                                    <td><span t-esc="line.move_name or ''"/></td>
                                    <td><span t-field="line.account_id"/></td>
                                    <td><span t-esc="line.label or ''"/></td>
                                    <td class="text-end">
                                        <span t-field="line.debit" t-options="{'widget': 'monetary', 'display_currency': doc.company_id.currency_id}"/>
                                    </td>
                                    <td class="text-end">
                                        <span t-field="line.credit" t-options="{'widget': 'monetary', 'display_currency': doc.company_id.currency_id}"/>
                                    </td>
                                    <td class="text-end">
                                        <span t-field="line.balance" t-options="{'widget': 'monetary', 'display_currency': doc.company_id.currency_id}"/>
                                    </td>
                                </tr>
                            </tbody>
                            <tfoot>
                                <tr>
                                    <td colspan="6" class="text-end"><strong>Total</strong></td>
                                    <td class="text-end">
                                        <strong t-esc="'{:,.2f}'.format(sum(doc.result_line_ids.mapped('debit')))"/>
                                    </td>
                                    <td class="text-end">
                                        <strong t-esc="'{:,.2f}'.format(sum(doc.result_line_ids.mapped('credit')))"/>
                                    </td>
                                    <td class="text-end">
                                        <strong t-esc="'{:,.2f}'.format(sum(doc.result_line_ids.mapped('line_balance')))"/>
                                    </td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
