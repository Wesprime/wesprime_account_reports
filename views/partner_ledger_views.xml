<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="war_partner_ledger_view_inherit" model="ir.ui.view">
        <field name="name">war.partner.ledger.view.inherit</field>
        <field name="model">account.report.partner.ledger</field>
        <field name="inherit_id" ref="base_accounting_kit.account_report_partner_ledger_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='result_selection']" position="after">
                <field name="partner_ids" widget="many2many_tags"/>
            </xpath>
            <xpath expr="//footer" position="replace">
                <footer>
                    <button name="action_view_partner_ledger" string="View" type="object" class="btn-primary"/>
                    <button name="check_report" string="Print" type="object" class="btn-secondary" default_focus="1"/>
                    <button name="action_export_partner_ledger_xlsx" string="Print Excel" type="object" class="btn-secondary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </xpath>
        </field>
    </record>
</odoo>
